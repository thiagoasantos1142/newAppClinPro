{
  "expo": {
    "name": "ClinApp",
    "slug": "clin-pro-2026",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/4a67a252-7a25-4c24-b41d-2a9fad8c110f"
    },
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.clinpro.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-secure-store",
        {
          "configureAndroidBackup": true,
          "faceIDPermission": "Allow $(PRODUCT_NAME) to access your Face ID biometric data."
        }
      ],
      "expo-video",
      "expo-audio",
      "expo-asset",
      "expo-file-system",
      [
        "expo-image-picker",
        {
          "photosPermission": "O ClinApp acessa suas fotos para permitir que voce escolha uma foto de perfil.",
          "colors": {
            "cropToolbarColor": "#000000"
          },
          "dark": {
            "colors": {
              "cropToolbarColor": "#000000"
            }
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "O ClinApp usa a camera para tirar fotos dos documentos e validar sua identidade.",
          "microphonePermission": "O ClinApp usa o microfone quando for necessario gravar audio pela camera.",
          "recordAudioAndroid": true,
          "barcodeScannerEnabled": true
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "4a67a252-7a25-4c24-b41d-2a9fad8c110f"
      }
    },
    "owner": "clinhouse"
  }
}
